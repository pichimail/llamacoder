# Copy this to .env.local (or .env) and fill in your values.
# This is required for local development and running prisma commands.

# === Database (REQUIRED) ===
# Get a free Postgres DB at https://neon.tech
# IMPORTANT: For serverless / Vercel use the **pooled** connection string.
# For `prisma migrate` you can use either (pooled or direct).
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Optional explicit Prisma pooled URL (Neon)
# POSTGRES_PRISMA_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# === AI Keys (at least one usually needed) ===
TOGETHER_API_KEY="sk-..."
# OPENROUTER_API_KEY="sk-or-..."

# === Auth ===
# Generate: openssl rand -base64 32
AUTH_SECRET="your-very-long-random-secret"

# Google login (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Other (from your deployment) ===
CSB_API_KEY=""
HELICONE_API_KEY=""
# CHINNALLM_... keys etc if using

# For purely local testing without forcing Google auth:
# REQUIRE_GOOGLE_AUTH=false
