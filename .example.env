# ===== REQUIRED: Database & Authentication =====
DATABASE_URL=postgresql://user:password@host:port/database
AUTH_SECRET=your-secret-key-here-use-openssl-rand-base64-32
NEXTAUTH_SECRET=${AUTH_SECRET}

# ===== REQUIRED: Google OAuth (for authentication) =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== REQUIRED: LLM Provider (at least one) =====
# Together AI
TOGETHER_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=LlamaCoder

# ===== REQUIRED: File Storage (Vercel Blob) =====
BLOB_READ_WRITE_TOKEN=

# ===== OPTIONAL: Rate Limiting (production recommended) =====
# Either Upstash Redis or Vercel KV
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Or use Vercel KV
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_URL=
KV_REST_API_READ_ONLY_TOKEN=

# ===== OPTIONAL: Admin Configuration =====
ADMIN_EMAIL=admin@example.com

# ===== OPTIONAL: Feature Flags =====
# Set to 'false' to allow unauthenticated local development
REQUIRE_GOOGLE_AUTH=true

# ===== OPTIONAL: Observability =====
HELICONE_API_KEY=

# ===== OPTIONAL: CodeSandbox Integration =====
CSB_API_KEY=

# ===== OPTIONAL: S3 Code Upload =====
S3_UPLOAD_REGION=
S3_UPLOAD_BUCKET=
S3_UPLOAD_SECRET=
S3_UPLOAD_KEY=

# ===== OPTIONAL: Braintrust Logging =====
BRAINTRUST_API_KEY=

# ===== OPTIONAL: Finetuned Model =====
FINETUNED_MODEL_ID=
NEXT_PUBLIC_FINETUNED_MODEL_ID=

# ===== OPTIONAL: GitHub Integration =====
GITHUB_REPOSITORY=owner/repo
