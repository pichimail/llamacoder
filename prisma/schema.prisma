generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GeneratedApp {
  id        String   @id @default(nanoid(5))
  model     String
  prompt    String
  code      String
  createdAt DateTime @default(now())

  @@index([id])
}

model Chat {
  id                String    @id @default(nanoid(16))
  model             String
  quality           String
  prompt            String
  title             String
  llamaCoderVersion String    @default("v2")
  shadcn            Boolean
  messages          Message[]
  projectId         String?
  project           Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  isPinned          Boolean   @default(false)
  isArchived        Boolean   @default(false)
  historySummary    String?
  historySummaryKey String?
  historySummaryAt  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([createdAt])
  @@index([projectId])
  @@index([isPinned, createdAt])
  @@index([isArchived])
}

model Message {
  id               String   @id @default(nanoid(16))
  role             String
  content          String
  files            Json?
  previewImageUrl  String?
  chatId           String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  position  Int
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([chatId, createdAt])
}

// ===== New Models for Project/Workspace =====
model Project {
  id              String       @id @default(nanoid(12))
  name            String
  description     String?
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats           Chat[]
  deployments     Deployment[]
  integrations    Integration[]
  domains         Domain[]
  envVars         EnvironmentVariable[]
  files           ProjectFile[]
  shareLinks      ShareLink[]
  members         ProjectMember[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Deployment {
  id            String   @id @default(nanoid(12))
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  previewUrl    String?
  productionUrl String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

model Integration {
  id        String   @id @default(nanoid(12))
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@unique([projectId, type])
}

model Domain {
  id        String   @id @default(nanoid(12))
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([projectId])
  @@unique([projectId, domain])
}

model EnvironmentVariable {
  id        String   @id @default(nanoid(12))
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@unique([projectId, key])
}

model ProjectFile {
  id        String   @id @default(nanoid(12))
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  path      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@unique([projectId, path])
}

model ShareLink {
  id        String   @id @default(nanoid(12))
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  token     String   @unique
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectMember {
  id        String   @id @default(nanoid(12))
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("editor")
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@unique([projectId, userId])
}

// ===== Admin-curated featured gallery pins =====
model FeaturedPin {
  id          String   @id @default(nanoid(12))
  slug        String   @unique
  messageId   String   @unique
  title       String
  description String   @default("")
  prompt      String   @default("")
  tags        Json?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([sortOrder, createdAt])
}

// ===== App settings / feature flags (admin-controlled) =====
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ===== Auth.js (NextAuth) models for SaaS mode =====
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          String    @default("free")
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  projectMembers ProjectMember[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
